<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MauiAppMinhasCompras.Views.NovoProduto"
             Title="Novo Produto"
             BackgroundColor="#F0F4F8">
    <ContentPage.ToolbarItems>
        <ToolbarItem Text="Salvar" Clicked="ToolbarItem_Clicked" />
    </ContentPage.ToolbarItems>

    <ScrollView>
        <VerticalStackLayout Spacing="24" Padding="20,30">

            <VerticalStackLayout Spacing="4" Margin="0,0,0,10">
                <Label Text="Adicionar Produto" FontSize="26" FontAttributes="Bold" TextColor="#1E293B" />
                <Label Text="Preencha os dados da sua nova compra." FontSize="14" TextColor="#64748B" />
            </VerticalStackLayout>

            <Border Stroke="#E2E8F0" StrokeThickness="1" BackgroundColor="White" Padding="20" Margin="0">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="16" />
                </Border.StrokeShape>
                <Border.Shadow>
                    <Shadow Brush="#0F172A" Offset="0,8" Radius="16" Opacity="0.05" />
                </Border.Shadow>

                <VerticalStackLayout Spacing="20">

                    <VerticalStackLayout Spacing="8">
                        <Label Text="Descrição do Produto" FontSize="14" FontAttributes="Bold" TextColor="#334155" />
                        <Border Stroke="#CBD5E1" StrokeThickness="1" BackgroundColor="#F8FAFC" Padding="12,4">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="8" />
                            </Border.StrokeShape>
                            <Entry x:Name="txt_descricao" 
                                   Placeholder="Ex: Arroz 5kg" 
                                   BackgroundColor="Transparent" 
                                   TextColor="#0F172A" 
                                   ClearButtonVisibility="WhileEditing" />
                        </Border>
                    </VerticalStackLayout>

                    <Grid ColumnDefinitions="*, *" ColumnSpacing="16">

                        <VerticalStackLayout Grid.Column="0" Spacing="8">
                            <Label Text="Quantidade" FontSize="14" FontAttributes="Bold" TextColor="#334155" />
                            <Border Stroke="#CBD5E1" StrokeThickness="1" BackgroundColor="#F8FAFC" Padding="12,4">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="8" />
                                </Border.StrokeShape>
                                <Entry x:Name="txt_quantidade" 
                                       Keyboard="Numeric" 
                                       Placeholder="Ex: 2" 
                                       BackgroundColor="Transparent" 
                                       TextColor="#0F172A" />
                            </Border>
                        </VerticalStackLayout>

                        <VerticalStackLayout Grid.Column="1" Spacing="8">
                            <Label Text="Preço (R$)" FontSize="14" FontAttributes="Bold" TextColor="#334155" />
                            <Border Stroke="#CBD5E1" StrokeThickness="1" BackgroundColor="#F8FAFC" Padding="12,4">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="8" />
                                </Border.StrokeShape>
                                <Entry x:Name="txt_preco" 
                                       Keyboard="Numeric" 
                                       Placeholder="0,00" 
                                       BackgroundColor="Transparent" 
                                       TextColor="#0F172A" />
                            </Border>
                        </VerticalStackLayout>
                    </Grid>

                </VerticalStackLayout>
            </Border>

            <Button Text="Salvar Produto" 
                    Clicked="ToolbarItem_Clicked"
                    BackgroundColor="#0EA5E9" 
                    TextColor="White" 
                    FontAttributes="Bold" 
                    FontSize="16" 
                    CornerRadius="12" 
                    HeightRequest="56" 
                    Margin="0,10,0,0">
                <Button.Shadow>
                    <Shadow Brush="#0EA5E9" Offset="0,4" Radius="10" Opacity="0.3" />
                </Button.Shadow>
            </Button>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>